<Window x:Class="EEGMonitor.Views.Dialogs.PlaybackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Data Playback" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#161B22" Foreground="#E6EDF3">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Session selector -->
            <RowDefinition Height="Auto"/>  <!-- Transport controls -->
            <RowDefinition Height="*"/>     <!-- Charts -->
            <RowDefinition Height="120"/>   <!-- Events timeline -->
        </Grid.RowDefinitions>

        <!-- Session selector -->
        <Border Grid.Row="0" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Session:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#8B949E" FontSize="11"/>
                <ComboBox x:Name="SessionCombo"
                          Background="#0D1117" Foreground="#E6EDF3" BorderBrush="#30363D"
                          Width="400" Height="28" FontSize="11"
                          SelectionChanged="SessionCombo_SelectionChanged"/>
                <Button Content="Load" Click="LoadClick" Margin="8,0,0,0"
                        Background="#238636" Foreground="White" BorderBrush="#2EA043"
                        Padding="12,4" Cursor="Hand" Height="28">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock x:Name="SessionInfoText" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="#8B949E" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Transport controls -->
        <Border Grid.Row="1" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="◀◀" Click="SeekStartClick" Width="36" Height="28"
                            Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D" Margin="0,0,4,0"/>
                    <Button x:Name="PlayPauseBtn" Content="▶ Play" Click="PlayPauseClick"
                            Background="#238636" Foreground="White" BorderBrush="#2EA043"
                            Padding="12,4" Height="28" Margin="0,0,4,0"/>
                    <Button Content="■ Stop" Click="StopClick"
                            Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                            Padding="12,4" Height="28" Margin="0,0,12,0"/>
                    <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#8B949E" FontSize="11"/>
                    <ComboBox x:Name="SpeedCombo" Width="60" Height="28" FontSize="11"
                              Background="#0D1117" Foreground="#E6EDF3" BorderBrush="#30363D"
                              SelectionChanged="SpeedCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Seek slider -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0">
                    <TextBlock x:Name="PositionText" Text="00:00" VerticalAlignment="Center"
                               Foreground="#58A6FF" FontFamily="Consolas" FontSize="12" Margin="0,0,8,0"/>
                    <Slider x:Name="SeekSlider" VerticalAlignment="Center" Width="400"
                            Minimum="0" Maximum="100"
                            ValueChanged="SeekSlider_ValueChanged"
                            Foreground="#58A6FF"/>
                    <TextBlock x:Name="DurationText" Text="00:00" VerticalAlignment="Center"
                               Foreground="#8B949E" FontFamily="Consolas" FontSize="12" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Live values -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#0D1117" Padding="10,4" CornerRadius="4" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="BIS" FontSize="9" Foreground="#8B949E" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="BisPlayback" Text="---" FontSize="20" FontWeight="Bold"
                                       Foreground="#58A6FF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1117" Padding="10,4" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="SpO₂" FontSize="9" Foreground="#8B949E" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SpO2Playback" Text="---" FontSize="20" FontWeight="Bold"
                                       Foreground="#4FC3F7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Charts -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <oxy:PlotView x:Name="WaveView" Grid.Column="0" Background="Transparent" Margin="0,0,4,0"/>
            <oxy:PlotView x:Name="TrendView" Grid.Column="1" Background="Transparent"/>
        </Grid>

        <!-- Events timeline -->
        <Border Grid.Row="3" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Clinical Events Timeline"
                           FontSize="10" Foreground="#8B949E" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="EventsTimeline">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas x:Name="TimelineCanvas" Height="60"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"
                                        Value="{Binding SessionOffset.TotalSeconds}"/>
                                <Setter Property="Canvas.Top" Value="0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel ToolTip="{Binding Notes}">
                                    <Line X1="0" Y1="0" X2="0" Y2="20"
                                          Stroke="#58A6FF" StrokeThickness="1.5"/>
                                    <Border Background="#21262D" BorderBrush="#30363D"
                                            BorderThickness="1" CornerRadius="3" Padding="4,2">
                                        <TextBlock Text="{Binding Label}" FontSize="9" Foreground="#E6EDF3"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
