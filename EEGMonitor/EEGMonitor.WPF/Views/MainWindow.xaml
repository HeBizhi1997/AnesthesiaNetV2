<Window x:Class="EEGMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:EEGMonitor.ViewModels"
        xmlns:conv="clr-namespace:EEGMonitor.Views.Converters"
        Title="EEG Monitor — Depth of Anesthesia"
        Height="900" Width="1600"
        MinHeight="720" MinWidth="1280"
        WindowState="Maximized"
        Background="{StaticResource BgDeepBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.Resources>
        <conv:BISColorConverter x:Key="BISColorConverter"/>
        <conv:NaNToStringConverter x:Key="NaNConv"/>
        <conv:BoolToVisConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <DockPanel Background="{StaticResource BgDeepBrush}">

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="20" Margin="0,0,8,0"
                               Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Text="EEG Monitor" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text=" | AnesthesiaNet v3" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Style="{StaticResource DarkComboStyle}"
                              ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding SelectedPort}"
                              Width="80" Height="26" FontSize="11"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding RefreshPortsCommand}"
                            Content="↻" Margin="4,0" Width="28" Height="26" FontSize="12"
                            ToolTip="Refresh ports"/>
                    <TextBlock Text="Baud:" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Style="{StaticResource DarkComboStyle}"
                              ItemsSource="{Binding BaudRates}"
                              SelectedItem="{Binding SelectedBaudRate}"
                              Width="80" Height="26" FontSize="11"/>
                    <Button Margin="12,0,0,0" Height="26" Width="90"
                            Command="{Binding ConnectCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="11">
                        <Button.Content>
                            <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToVis},
                                       ConverterParameter='Disconnect|Connect'}"/>
                        </Button.Content>
                    </Button>
                    <Separator Margin="12,0" Background="{StaticResource BorderBrush}" Width="1"/>
                    <TextBlock Text="Patient:" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding PatientId, UpdateSourceTrigger=PropertyChanged}"
                             Width="90" Height="26" FontSize="11" ToolTip="Patient ID"/>
                    <TextBlock Text="Surgery:" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding SurgeryType, UpdateSourceTrigger=PropertyChanged}"
                             Width="110" Height="26" FontSize="11" ToolTip="Surgery type"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="10" Padding="8,3" Margin="4,0"
                            Background="{Binding IsServiceOnline, Converter={StaticResource BoolToVis},
                                         ConverterParameter='#1A3A1A|#3A1A1A'}">
                        <TextBlock FontSize="10">
                            <Run Text="● Python: "/>
                            <Run Text="{Binding IsServiceOnline, Converter={StaticResource BoolToVis},
                                                ConverterParameter='在线|离线'}"/>
                        </TextBlock>
                    </Border>
                    <Border CornerRadius="10" Padding="8,3" Margin="4,0"
                            Background="{Binding IsConnected, Converter={StaticResource BoolToVis},
                                         ConverterParameter='#1A3A1A|#2D2D2D'}">
                        <TextBlock FontSize="10" Text="{Binding StatusMessage}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ BOTTOM TOOLBAR ════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Event:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    <ComboBox Style="{StaticResource DarkComboStyle}"
                              ItemsSource="{Binding EventTypeOptions}"
                              SelectedItem="{Binding SelectedEventType}"
                              Width="120" Height="28" FontSize="11"/>
                    <TextBox Style="{StaticResource DarkTextBoxStyle}"
                             Text="{Binding NewEventLabel, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Height="28" FontSize="11" Margin="6,0"
                             ToolTip="Event label / note"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding AddEventCommand}"
                            Content="+ Add Event" Height="28" Padding="10,4" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" Fill="Red"
                             Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding RecordingDuration}" FontSize="13" FontFamily="Consolas"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartRecordingCommand}"
                            Content="● Record" Height="28" Padding="10,4" FontSize="11" Margin="0,0,6,0"
                            Visibility="{Binding IsRecording, Converter={StaticResource InvBoolToVis}}"/>
                    <Button Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding StopRecordingCommand}"
                            Content="■ Stop" Height="28" Padding="10,4" FontSize="11" Margin="0,0,6,0"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding OpenPlaybackCommand}"
                            Content="▶ Playback" Height="28" Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                    <Button Command="{Binding OpenSimulationCommand}"
                            Height="28" Padding="10,4" FontSize="11" Margin="0,0,6,0" Cursor="Hand"
                            ToolTip="从 VitalDB .vital 文件模拟实时 EEG 信号">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                <Setter Property="BorderBrush" Value="#30363D"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                        <Setter Property="Background" Value="#0E4429"/>
                                        <Setter Property="BorderBrush" Value="#2EA043"/>
                                        <Setter Property="Foreground" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞ 信号模拟"/>
                                <TextBlock Margin="6,0,0,0" FontSize="9" VerticalAlignment="Center"
                                           Text="{Binding SimulationStatus}" Foreground="#3FB950"
                                           Visibility="{Binding IsSimulating, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding OpenSettingsCommand}"
                            Content="⚙ Settings" Height="28" Padding="10,4" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CLINICAL EVENTS TIMELINE ═══════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="80">
            <Grid Margin="8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Clinical Events Timeline"
                           FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ClinicalEvents}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,0" Padding="8,4" CornerRadius="4"
                                        Background="#2D333B" BorderBrush="#30363D" BorderThickness="1"
                                        ToolTip="{Binding Notes}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                                   FontSize="9" Foreground="#8B949E" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding EventType}"
                                                   FontSize="9" Foreground="#58A6FF" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>   <!-- Left: EEG waves + DSA -->
                <ColumnDefinition Width="2*"/>   <!-- Right: BIS + Vitals + Trend + Powers -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: 7 stacked wave strips + DSA ───────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>  <!-- 7 wave strips (10-second rolling) -->
                    <RowDefinition Height="2*"/>  <!-- DSA spectrogram -->
                </Grid.RowDefinitions>

                <!-- 6 wave strips (10-second rolling): δ θ α β γ + Pulse -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <oxy:PlotView Grid.Row="0" Model="{Binding DeltaModel}"
                                      Background="Transparent" Margin="1"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding ThetaModel}"
                                      Background="Transparent" Margin="1"/>
                        <oxy:PlotView Grid.Row="2" Model="{Binding AlphaModel}"
                                      Background="Transparent" Margin="1"/>
                        <oxy:PlotView Grid.Row="3" Model="{Binding BetaModel}"
                                      Background="Transparent" Margin="1"/>
                        <oxy:PlotView Grid.Row="4" Model="{Binding GammaModel}"
                                      Background="Transparent" Margin="1"/>
                        <oxy:PlotView Grid.Row="5" Model="{Binding PulseWaveModel}"
                                      Background="Transparent" Margin="1"/>
                    </Grid>
                </Border>

                <!-- DSA Spectrogram -->
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <oxy:PlotView Model="{Binding DsaModel}" Background="Transparent"/>
                </Border>
            </Grid>

            <!-- ── RIGHT: BIS (dominant) + Vitals + BIS Trend + Band Powers ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3.5*"/>  <!-- BIS — dominant display -->
                    <RowDefinition Height="2*"/>    <!-- SpO2 + HR — large -->
                    <RowDefinition Height="0.8*"/>  <!-- SQI + HRV — compact row -->
                    <RowDefinition Height="2*"/>    <!-- BIS Trend -->
                    <RowDefinition Height="1.7*"/> <!-- Band Power Distribution -->
                </Grid.RowDefinitions>

                <!-- ── BIS (left) + Entropy SE/RE (right) ─────────────────── -->
                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>   <!-- BIS dominant -->
                            <ColumnDefinition Width="Auto"/> <!-- divider -->
                            <ColumnDefinition Width="2*"/>   <!-- SE / RE -->
                        </Grid.ColumnDefinitions>

                        <!-- BIS -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="BIS  麻醉深度指数" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding BisDisplay}"
                                       FontSize="80" FontWeight="Bold" FontFamily="Consolas"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding BisValue, Converter={StaticResource BISColorConverter}}"/>
                            <TextBlock Text="{Binding BisZoneDisplay}"
                                       FontSize="18" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"
                                       Foreground="{Binding BisValue, Converter={StaticResource BISColorConverter}}"/>
                            <TextBlock FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,5,0,0">
                                <Run Text="&lt;40 过深   "/><Run Text="40-60 适宜" Foreground="#3FB950"/>
                                <Run Text="   60-80 偏浅   "/><Run Text=">80 清醒" Foreground="#F85149"/>
                            </TextBlock>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}"
                                   VerticalAlignment="Stretch" Margin="0,16"/>

                        <!-- Spectral Entropy: SE + RE -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="熵指数" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>

                            <!-- SE -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="SE  状态熵" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SeDisplay}"
                                           FontSize="52" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding SeValue, Converter={StaticResource BISColorConverter}}"/>
                                <TextBlock Text="(0 – 91)" FontSize="9"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- RE -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="RE  反应熵" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ReDisplay}"
                                           FontSize="52" FontWeight="Bold" FontFamily="Consolas"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding ReValue, Converter={StaticResource BISColorConverter}}"/>
                                <TextBlock Text="(0 – 100)" FontSize="9"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- RE - SE difference: EMG indicator -->
                            <Border Background="#1A1F27" CornerRadius="4" Padding="8,4" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="RE − SE  肌电指示" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ReSeDiffDisplay}"
                                               FontSize="24" FontWeight="Bold" FontFamily="Consolas"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource YellowWarnBrush}"/>
                                    <TextBlock Text="≥10 有肌电活动" FontSize="8"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SpO2 + Heart Rate ────────────────────────────────────── -->
                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="SpO₂" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SpO2Display}" FontSize="52" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentCyanBrush}"/>
                            <TextBlock Text="脉搏血氧" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1"
                                   Fill="{StaticResource BorderBrush}" VerticalAlignment="Stretch" Margin="0,12"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="HR" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding HeartRateDisplay}" FontSize="52" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Foreground="{StaticResource GreenOkBrush}"/>
                            <TextBlock Text="bpm  心率" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── SQI + HRV compact row ─────────────────────────────────── -->
                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="SQI: " FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SqiDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource YellowWarnBrush}" VerticalAlignment="Center"/>
                        <Rectangle Width="1" Margin="16,4" Fill="{StaticResource BorderBrush}"
                                   VerticalAlignment="Stretch"/>
                        <TextBlock Text="HRV: " FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding HrvDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource GreenOkBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── BIS Trend (5 minutes) ─────────────────────────────────── -->
                <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                    <oxy:PlotView Model="{Binding TrendModel}" Background="Transparent"/>
                </Border>

                <!-- ── EEG Band Power Distribution ───────────────────────────── -->
                <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="EEG 频带功率分布"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="4,2,0,4"/>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Delta -->
                            <Grid Grid.Row="0" Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="δ delta" FontSize="11"
                                           Foreground="{StaticResource DeltaBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="16"
                                             Value="{Binding DeltaPower}" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource DeltaBrush}"
                                             Background="#21262D" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Foreground="{StaticResource DeltaBrush}">
                                    <Run Text="{Binding DeltaPower, StringFormat=F1}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>

                            <!-- Theta -->
                            <Grid Grid.Row="1" Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="θ theta" FontSize="11"
                                           Foreground="{StaticResource ThetaBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="16"
                                             Value="{Binding ThetaPower}" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource ThetaBrush}"
                                             Background="#21262D" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Foreground="{StaticResource ThetaBrush}">
                                    <Run Text="{Binding ThetaPower, StringFormat=F1}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>

                            <!-- Alpha -->
                            <Grid Grid.Row="2" Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="α alpha" FontSize="11"
                                           Foreground="{StaticResource AlphaBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="16"
                                             Value="{Binding AlphaPower}" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource AlphaBrush}"
                                             Background="#21262D" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Foreground="{StaticResource AlphaBrush}">
                                    <Run Text="{Binding AlphaPower, StringFormat=F1}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>

                            <!-- Beta -->
                            <Grid Grid.Row="3" Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="β beta" FontSize="11"
                                           Foreground="{StaticResource BetaBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="16"
                                             Value="{Binding BetaPower}" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource BetaBrush}"
                                             Background="#21262D" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Foreground="{StaticResource BetaBrush}">
                                    <Run Text="{Binding BetaPower, StringFormat=F1}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>

                            <!-- Gamma -->
                            <Grid Grid.Row="4" Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="γ gamma" FontSize="11"
                                           Foreground="{StaticResource GammaBrush}" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Height="16"
                                             Value="{Binding GammaPower}" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource GammaBrush}"
                                             Background="#21262D" BorderThickness="0"/>
                                <TextBlock Grid.Column="2" FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Foreground="{StaticResource GammaBrush}">
                                    <Run Text="{Binding GammaPower, StringFormat=F1}"/><Run Text="%"/>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
