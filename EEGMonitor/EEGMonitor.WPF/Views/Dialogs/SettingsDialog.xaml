<Window x:Class="EEGMonitor.Views.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#161B22" Foreground="#E6EDF3"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="16" FontWeight="Bold"
                   Foreground="#E6EDF3" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <!-- Python Service URL -->
            <TextBlock Text="Python Processing Service URL" FontSize="11"
                       Foreground="#8B949E" Margin="0,0,0,4"/>
            <TextBox x:Name="ServiceUrlBox" Text="http://localhost:8765"
                     Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                     Padding="6,4" Height="28" FontSize="11" Margin="0,0,0,16"/>

            <!-- Sample Rate -->
            <TextBlock Text="EEG Sample Rate (Hz)" FontSize="11"
                       Foreground="#8B949E" Margin="0,0,0,4"/>
            <ComboBox x:Name="SampleRateCombo"
                      Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                      Height="28" FontSize="11" Margin="0,0,0,16"/>

            <!-- Channel count -->
            <TextBlock Text="EEG Channels" FontSize="11"
                       Foreground="#8B949E" Margin="0,0,0,4"/>
            <ComboBox x:Name="ChannelCombo"
                      Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                      Height="28" FontSize="11" Margin="0,0,0,16"/>

            <!-- Alert thresholds -->
            <TextBlock Text="Alert Thresholds" FontSize="12" FontWeight="SemiBold"
                       Foreground="#E6EDF3" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="BIS Low Alert" FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                    <TextBox x:Name="BisLowBox" Text="40"
                             Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                             Padding="6,4" Height="28" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="BIS High Alert" FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                    <TextBox x:Name="BisHighBox" Text="70"
                             Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                             Padding="6,4" Height="28" FontSize="11"/>
                </StackPanel>
            </Grid>
            <StackPanel>
                <TextBlock Text="SpO₂ Low Alert (%)" FontSize="11" Foreground="#8B949E" Margin="0,0,0,4"/>
                <TextBox x:Name="SpO2LowBox" Text="90"
                         Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                         Padding="6,4" Height="28" FontSize="11" Width="120" HorizontalAlignment="Left"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Click="CancelClick" Padding="16,6" Margin="0,0,8,0" Cursor="Hand"
                    Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Click="SaveClick" Padding="16,6" Cursor="Hand"
                    Background="#238636" Foreground="White" BorderBrush="#2EA043">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
