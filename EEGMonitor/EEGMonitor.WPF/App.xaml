<Application x:Class="EEGMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Color Palette ── -->
            <Color x:Key="BgDeepColor">#0D1117</Color>
            <Color x:Key="BgPanelColor">#161B22</Color>
            <Color x:Key="BgCardColor">#21262D</Color>
            <Color x:Key="BorderColor">#30363D</Color>
            <Color x:Key="TextPrimaryColor">#E6EDF3</Color>
            <Color x:Key="TextSecondaryColor">#8B949E</Color>
            <Color x:Key="AccentCyanColor">#58A6FF</Color>
            <Color x:Key="GreenOkColor">#3FB950</Color>
            <Color x:Key="YellowWarnColor">#D29922</Color>
            <Color x:Key="RedCritColor">#F85149</Color>

            <!-- Wave Colors -->
            <Color x:Key="DeltaColor">#4FC3F7</Color>
            <Color x:Key="ThetaColor">#81C784</Color>
            <Color x:Key="AlphaColor">#FFB74D</Color>
            <Color x:Key="BetaColor">#F06292</Color>
            <Color x:Key="GammaColor">#CE93D8</Color>

            <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}"/>
            <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanelColor}"/>
            <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyanColor}"/>
            <SolidColorBrush x:Key="GreenOkBrush" Color="{StaticResource GreenOkColor}"/>
            <SolidColorBrush x:Key="YellowWarnBrush" Color="{StaticResource YellowWarnColor}"/>
            <SolidColorBrush x:Key="RedCritBrush" Color="{StaticResource RedCritColor}"/>

            <!-- Wave brushes -->
            <SolidColorBrush x:Key="DeltaBrush" Color="{StaticResource DeltaColor}"/>
            <SolidColorBrush x:Key="ThetaBrush" Color="{StaticResource ThetaColor}"/>
            <SolidColorBrush x:Key="AlphaBrush" Color="{StaticResource AlphaColor}"/>
            <SolidColorBrush x:Key="BetaBrush" Color="{StaticResource BetaColor}"/>
            <SolidColorBrush x:Key="GammaBrush" Color="{StaticResource GammaColor}"/>

            <!-- ── Global Styles ── -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            </Style>

            <Style TargetType="Button" x:Key="ActionButtonStyle">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D333B"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1C2128"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#238636"/>
                <Setter Property="BorderBrush" Value="#2EA043"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="Background" Value="#B62324"/>
                <Setter Property="BorderBrush" Value="#F85149"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style TargetType="ComboBox" x:Key="DarkComboStyle">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>

            <Style TargetType="TextBox" x:Key="DarkTextBoxStyle">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="Padding" Value="6,4"/>
            </Style>

            <!-- Panel card style -->
            <Style TargetType="Border" x:Key="CardBorderStyle">
                <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="6"/>
                <Setter Property="Margin" Value="3"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
