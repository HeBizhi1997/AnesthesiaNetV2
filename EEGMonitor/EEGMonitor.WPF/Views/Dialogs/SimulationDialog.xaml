<Window x:Class="EEGMonitor.Views.Dialogs.SimulationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EEG 信号模拟器 — VitalDB" Height="640" Width="540"
        Background="#161B22" Foreground="#E6EDF3"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Reusable label style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <!-- Dark ComboBox -->
        <Style x:Key="DkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <!-- Dark TextBox -->
        <Style x:Key="DkTb" TargetType="TextBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="CaretBrush" Value="#E6EDF3"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- File selector -->
            <RowDefinition Height="Auto"/>  <!-- Info bar -->
            <RowDefinition Height="Auto"/>  <!-- Track mapping -->
            <RowDefinition Height="Auto"/>  <!-- Playback settings -->
            <RowDefinition Height="Auto"/>  <!-- Progress -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ① File selector ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Vital 文件路径" Style="{StaticResource LabelStyle}"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="FilePathBox"
                             Style="{StaticResource DkTb}" Margin="0,0,6,0"
                             ToolTip="选择 .vital 文件"/>
                    <Button Grid.Column="1" Content="浏览..." Click="BrowseClick"
                            Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                            Padding="10,4" Height="28" FontSize="11" Margin="0,0,6,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2D333B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="查询轨道" Click="QueryTracksClick"
                            Background="#1F6FEB" Foreground="White" BorderBrush="#388BFD"
                            Padding="10,4" Height="28" FontSize="11" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#388BFD"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ② File info bar ──────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="文件信息：" Style="{StaticResource LabelStyle}" Margin="0"/>
                <TextBlock x:Name="FileInfoText"
                           Text="— 请先选择文件并查询轨道 —"
                           FontSize="11" Foreground="#58A6FF" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ③ Track mapping ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="轨道映射"
                           FontSize="11" FontWeight="SemiBold" Foreground="#E6EDF3" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="EEG 通道 1 (δ/θ/α/β)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="Eeg1Combo" Style="{StaticResource DkCombo}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="EEG 通道 2" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="Eeg2Combo" Style="{StaticResource DkCombo}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="脉搏波 (PPG)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="PulseCombo" Style="{StaticResource DkCombo}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="SpO₂" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="Spo2Combo" Style="{StaticResource DkCombo}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="心率 (HR)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="HrCombo" Style="{StaticResource DkCombo}"/>
            </Grid>
        </Border>

        <!-- ④ Playback settings ──────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="回放速度" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="SpeedCombo" Style="{StaticResource DkCombo}" Width="120"
                              HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="目标采样率 (Hz)" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="SampleRateCombo" Style="{StaticResource DkCombo}" Width="120"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ⑤ Progress ───────────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="#21262D" BorderBrush="#30363D"
                BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProgressLabel" Grid.Column="0"
                               Text="准备就绪" FontSize="11" Foreground="#8B949E"/>
                    <TextBlock x:Name="TimeText" Grid.Column="1"
                               Text="--:--:-- / --:--:--"
                               FontSize="11" FontFamily="Consolas" Foreground="#58A6FF"/>
                </Grid>
                <ProgressBar Grid.Row="1" x:Name="ProgressBar"
                             Height="6" Value="0" Maximum="100"
                             Background="#0D1117" Foreground="#58A6FF" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ⑥ Action buttons ─────────────────────────────────────────── -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="加载文件" x:Name="LoadBtn"
                    Click="LoadFileClick" IsEnabled="False"
                    Background="#9E6A03" Foreground="White" BorderBrush="#BB8009"
                    Padding="12,6" Height="32" FontSize="11" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- spacer -->
            <StackPanel Grid.Column="1"/>

            <Button Grid.Column="2" Content="▶ 开始模拟" x:Name="StartBtn"
                    Click="StartClick" IsEnabled="False"
                    Background="#238636" Foreground="White" BorderBrush="#2EA043"
                    Padding="14,6" Height="32" FontSize="11" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="3" Content="⏸ 暂停" x:Name="PauseBtn"
                    Click="PauseClick" IsEnabled="False"
                    Background="#21262D" Foreground="#E6EDF3" BorderBrush="#30363D"
                    Padding="12,6" Height="32" FontSize="11" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="4" Content="■ 停止" x:Name="StopBtn"
                    Click="StopClick" IsEnabled="False"
                    Background="#B62324" Foreground="White" BorderBrush="#F85149"
                    Padding="12,6" Height="32" FontSize="11" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
